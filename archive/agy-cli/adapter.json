{
  "id": "agy-cli",
  "displayName": "AGY-CLI (Antigravity-CLI)",
  "kind": "cli",
  "binary": {
    "windows": [
      "%LOCALAPPDATA%\\agy\\bin\\agy.exe",
      "agy"
    ],
    "macos": [
      "/usr/local/bin/agy",
      "$HOME/.local/bin/agy",
      "agy"
    ],
    "linux": [
      "$HOME/.local/bin/agy",
      "/usr/local/bin/agy",
      "agy"
    ]
  },
  "isolation": {
    "strategy": "redirectHome",
    "shareFromRealHome": [".gitconfig", ".ssh"]
  },
  "share": {
    "systemHome": "$HOME/.agy",
    "linkable": [],
    "neverLink": ["auth.json", "conversations", "credentials", "sessions", "plugins", "oauth_creds.json", ".credentials.json"]
  },
  "install": "https://antigravity.google.com/",
  "versionCommand": ["--version"],
  "status": "stable",
  "notes": "AGY-CLI uses redirectHome with full TEMP/TMP isolation."
}
