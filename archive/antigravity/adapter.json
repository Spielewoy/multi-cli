{
  "id": "antigravity",
  "displayName": "Google Antigravity",
  "kind": "hybrid",
  "binary": {
    "windows": [
      "%LOCALAPPDATA%\\Programs\\Antigravity\\Antigravity.exe",
      "antigravity"
    ],
    "macos": [
      "/Applications/Antigravity.app/Contents/MacOS/Antigravity",
      "$HOME/Applications/Antigravity.app/Contents/MacOS/Antigravity"
    ],
    "linux": [
      "/usr/bin/antigravity",
      "/opt/Antigravity/antigravity",
      "$HOME/.local/bin/antigravity"
    ]
  },
  "isolation": {
    "strategy": "sandboxUser",
    "args": [
      "--user-data-dir", "{profileDir}/data",
      "--extensions-dir", "{profileDir}/extensions"
    ]
  },
  "share": {
    "systemHome": "$HOME/.antigravity",
    "linkable": [],
    "neverLink": ["auth.json", "credentials", "sessions", "cookies", "Local Storage", "IndexedDB"]
  },
  "install": "https://antigravity.google.com/",
  "versionCommand": ["--version"],
  "status": "stable",
  "notes": "Antigravity is an Electron-based IDE. Like all Electron apps, it ignores HOME/APPDATA env vars for its internal data storage. The only way to achieve full isolation is --user-data-dir, which redirects ALL app state (auth tokens, sessions, cookies, extensions, local storage) to a profile-specific directory. This ensures zero leakage between profiles and allows multiple accounts."
}
