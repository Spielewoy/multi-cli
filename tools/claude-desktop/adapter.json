{
  "id": "claude-desktop",
  "displayName": "Claude Desktop",
  "kind": "desktop",
  "binary": {
    "windows": [
      "%LOCALAPPDATA%\\AnthropicClaude\\Claude.exe",
      "%LOCALAPPDATA%\\Programs\\Claude\\Claude.exe"
    ],
    "macos": [
      "/Applications/Claude.app/Contents/MacOS/Claude",
      "$HOME/Applications/Claude.app/Contents/MacOS/Claude"
    ],
    "linux": []
  },
  "isolation": {
    "strategy": "redirectHome",
    "homeSubdir": "AppData/Roaming/Claude",
    "shareFromRealHome": [".gitconfig", ".ssh", ".npmrc"]
  },
  "share": {
    "systemHome":  "%APPDATA%/Claude",
    "linkable":    ["claude_desktop_config.json"],
    "neverLink":   []
  },
  "install": "https://claude.ai/download",
  "versionCommand": ["--version"],
  "status": "beta",
  "notes": "Claude Desktop has no documented profile flag. We redirect HOME/USERPROFILE to a per-profile dir which contains a fake AppData. Marked beta because it is not verified live in this repo's smoke tests."
}
